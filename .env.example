# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret-string-at-least-32-chars

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password to access /admin — pick anything you'll remember
ADMIN_PASSWORD=your-admin-password-here

# ── Challenge ─────────────────────────────────────────────────────────────────
# The password family members enter to join the 2026 challenge
CHALLENGE_PASSWORD=Bluejays

# ── App URL ───────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (update after first deploy)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
