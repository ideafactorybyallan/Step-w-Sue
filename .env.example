# Variables marked REQUIRED will cause the app to fail (startup error or
# 401/403/503 on the relevant routes) if they're missing or empty in production.

# ── Supabase ─────────────────────────────────────────────────────────────────
# REQUIRED — get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — app throws at startup if missing.
# Generate a random secret: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret-string-at-least-32-chars

# ── Admin ─────────────────────────────────────────────────────────────────────
# REQUIRED — /admin login is blocked when this is empty.
# Password to access /admin — pick anything you'll remember.
ADMIN_PASSWORD=your-admin-password-here

# ── Challenge ─────────────────────────────────────────────────────────────────
# REQUIRED — /api/auth/verify-challenge returns 503 if this is empty.
# The password family members enter on /join. Pick a word your family knows.
CHALLENGE_PASSWORD=pick-a-family-word

# ── App URL ───────────────────────────────────────────────────────────────────
# Optional — your Vercel deployment URL (update after first deploy).
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
